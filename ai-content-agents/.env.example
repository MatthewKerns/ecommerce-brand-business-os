# Amazon SP-API Credentials
# Get these from Amazon Seller Central > Apps & Services > Develop Apps
# Documentation: https://developer-docs.amazon.com/sp-api/docs/registering-your-application

# Your Amazon Seller/Merchant ID (found in Seller Central > Settings > Account Info)
AMAZON_SELLER_ID=your_seller_id_here

# LWA (Login with Amazon) OAuth credentials from your SP-API app
AMAZON_SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_SP_API_CLIENT_SECRET=your_client_secret_here

# LWA Refresh Token (generated using the SP-API authorization workflow)
# Tutorial: https://developer-docs.amazon.com/sp-api/docs/self-authorization
AMAZON_SP_API_REFRESH_TOKEN=Atzr|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Region for SP-API endpoints
# Common values: us-east-1 (NA), eu-west-1 (EU), us-west-2 (FE)
AMAZON_SP_API_REGION=us-east-1

# Amazon Marketplace ID
# US: ATVPDKIKX0DER, CA: A2EUQ1WTGCTBG2, MX: A1AM78C64UM0Y8
# UK: A1F83G8C2ARO7P, DE: A1PA6795UKMFR9, FR: A13V1IB3VIYZZH
# Full list: https://developer-docs.amazon.com/sp-api/docs/marketplace-ids
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
